rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- PROPOSALS COLLECTION ---
    match /proposals/{proposalId} {
      function isValidProposal(data) {
        return data.customerName is string && data.customerName.size() <= 200 &&
               (data.customerCpf == null || (data.customerCpf is string && data.customerCpf.size() <= 20)) &&
               data.carModel is string && data.carModel.size() <= 100 &&
               data.carYear is number &&
               data.carPrice is number && data.carPrice > 0 &&
               data.downPayment is number && data.downPayment >= 0 &&
               data.installmentCount is number &&
               data.interestRate is number &&
               data.firstDueDate is string &&
               (data.notes == null || data.notes is string) &&
               data.installmentValue is number &&
               data.installments is list &&
               data.status in ['draft', 'pending', 'approved', 'rejected', 'completed'] &&
               data.userId == request.auth.uid;
      }

      allow create: if isSignedIn() && 
                      isValidProposal(request.resource.data) &&
                      request.resource.data.createdAt is timestamp;

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() && 
                      resource.data.userId == request.auth.uid &&
                      isValidProposal(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      request.resource.data.updatedAt is timestamp;

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- CUSTOMERS COLLECTION ---
    match /customers/{customerId} {
      function isValidCustomer(data) {
        return data.name is string && data.name.size() <= 200 &&
               data.cpf is string && data.cpf.size() <= 20;
      }

      allow create: if isSignedIn() && isValidCustomer(request.resource.data);
      allow read: if isSignedIn(); // Customers might be shared in a real dealership, but keeping it simple
      allow update: if isSignedIn() && isValidCustomer(request.resource.data);
      allow delete: if false; // Archive instead
    }
  }
}
